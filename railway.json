{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "sh -c 'gunicorn dfinans_live_backend:app --bind 0.0.0.0:${PORT:-5055} --worker-class gthread --workers 1 --threads 4 --timeout 30'",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  }
}
